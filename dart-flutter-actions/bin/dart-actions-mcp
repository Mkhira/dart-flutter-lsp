#!/usr/bin/env bash
#
# dart-actions-mcp — launcher for the dart-flutter-actions MCP server.
#
# It applies the SAME SDK-discovery discipline as the dart-flutter-lsp plugin's
# bin/dart-lsp launcher (the two plugins are distributed separately, so each
# ships its own copy), additionally locates `flutter`, and then execs the Dart
# MCP server, passing the resolved executables via DART_BIN / FLUTTER_BIN.
#
# MCP transport rule: stdout is reserved for MCP protocol messages only. Every
# log/diagnostic/error from this script goes to stderr.
#
# Debug: DART_FLUTTER_ACTIONS_DEBUG=1 logs discovery details to stderr.

set -euo pipefail

# --- logging (stderr only) --------------------------------------------------

debug() { [ "${DART_FLUTTER_ACTIONS_DEBUG:-}" = "1" ] && printf '[dart-actions][debug] %s\n' "$*" >&2 || true; }
fail()  { printf '[dart-actions] ERROR: %s\n' "$*" >&2; }

# Portable symlink resolver (readlink -f is unavailable on macOS).
resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    local link
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *)  target="$(cd "$(dirname "$target")" >/dev/null 2>&1 && pwd)/$link" ;;
    esac
  done
  printf '%s' "$target"
}

DART_BIN=""
FLUTTER_BIN=""
FLUTTER_SDK_ROOT=""

# --- Dart discovery (mirrors bin/dart-lsp) ----------------------------------

discover_dart() {
  if [ -n "${DART_SDK:-}" ] && [ -x "$DART_SDK/bin/dart" ]; then
    DART_BIN="$DART_SDK/bin/dart"; debug "dart via DART_SDK"; return 0
  fi
  if [ -n "${FLUTTER_ROOT:-}" ]; then
    if [ -x "$FLUTTER_ROOT/bin/cache/dart-sdk/bin/dart" ]; then
      DART_BIN="$FLUTTER_ROOT/bin/cache/dart-sdk/bin/dart"; FLUTTER_SDK_ROOT="$FLUTTER_ROOT"
      debug "dart via FLUTTER_ROOT bundled sdk"; return 0
    fi
    if [ -x "$FLUTTER_ROOT/bin/dart" ]; then
      DART_BIN="$FLUTTER_ROOT/bin/dart"; FLUTTER_SDK_ROOT="$FLUTTER_ROOT"
      debug "dart via FLUTTER_ROOT shim"; return 0
    fi
  fi
  if command -v dart >/dev/null 2>&1; then
    DART_BIN="$(command -v dart)"; debug "dart via PATH: $DART_BIN"; return 0
  fi
  if command -v flutter >/dev/null 2>&1; then
    local fbin freal froot cand
    fbin="$(command -v flutter)"
    freal="$(resolve_link "$fbin")"
    froot="$(cd "$(dirname "$freal")/.." >/dev/null 2>&1 && pwd)"
    cand="$froot/bin/cache/dart-sdk/bin/dart"
    if [ -x "$cand" ]; then
      DART_BIN="$cand"; FLUTTER_SDK_ROOT="$froot"; debug "dart via resolved flutter root"; return 0
    fi
    if [ -x "$froot/bin/dart" ]; then
      DART_BIN="$froot/bin/dart"; FLUTTER_SDK_ROOT="$froot"; debug "dart via flutter root shim"; return 0
    fi
  fi
  local roots=(
    "$HOME/flutter" "$HOME/development/flutter" "$HOME/src/flutter"
    "$HOME/fvm/default" "/opt/flutter" "/usr/local/flutter"
    "/opt/homebrew/bin" "/usr/local/bin"
  )
  local r cand
  for r in "${roots[@]}"; do
    cand="$r/bin/cache/dart-sdk/bin/dart"
    if [ -x "$cand" ]; then DART_BIN="$cand"; FLUTTER_SDK_ROOT="$r"; debug "dart via $r"; return 0; fi
    if [ -x "$r/dart" ]; then DART_BIN="$r/dart"; debug "dart via $r"; return 0; fi
  done
  return 1
}

# --- Flutter discovery (optional; used for `flutter pub get`) ----------------

discover_flutter() {
  if [ -n "${FLUTTER_ROOT:-}" ] && [ -x "$FLUTTER_ROOT/bin/flutter" ]; then
    FLUTTER_BIN="$FLUTTER_ROOT/bin/flutter"; return 0
  fi
  if command -v flutter >/dev/null 2>&1; then
    FLUTTER_BIN="$(command -v flutter)"; return 0
  fi
  # If we already found a Flutter SDK root while resolving dart, use its flutter.
  if [ -n "$FLUTTER_SDK_ROOT" ] && [ -x "$FLUTTER_SDK_ROOT/bin/flutter" ]; then
    FLUTTER_BIN="$FLUTTER_SDK_ROOT/bin/flutter"; return 0
  fi
  # If dart came from a Flutter cache, derive the flutter shim from its path.
  case "$DART_BIN" in
    */bin/cache/dart-sdk/bin/dart)
      local froot="${DART_BIN%/bin/cache/dart-sdk/bin/dart}"
      if [ -x "$froot/bin/flutter" ]; then FLUTTER_BIN="$froot/bin/flutter"; return 0; fi
      ;;
  esac
  return 1
}

# --- main -------------------------------------------------------------------

if ! discover_dart || [ -z "$DART_BIN" ]; then
  fail "No usable Dart SDK found."
  fail "Set DART_SDK or FLUTTER_ROOT, add 'dart' to PATH, or install Dart/Flutter:"
  fail "  https://dart.dev/get-dart  |  https://docs.flutter.dev/get-started/install"
  exit 1
fi

discover_flutter || debug "no flutter executable found (dart-only actions still work)"

PLUGIN_ROOT="$(cd "$(dirname "$(resolve_link "${BASH_SOURCE[0]}")")/.." >/dev/null 2>&1 && pwd)"
SERVER="$PLUGIN_ROOT/server/dart_actions_server.dart"

if [ ! -f "$SERVER" ]; then
  fail "MCP server script not found: $SERVER"
  exit 1
fi

if [ "${DART_FLUTTER_ACTIONS_DEBUG:-}" = "1" ]; then
  debug "dart executable : $DART_BIN"
  debug "flutter executable: ${FLUTTER_BIN:-<none>}"
  debug "server script   : $SERVER"
  debug "working directory: $(pwd)"
fi

export DART_BIN
export FLUTTER_BIN

# Hand off to the Dart MCP server (stdio JSON-RPC). Core-library script, so no
# pub get is required.
exec "$DART_BIN" "$SERVER" "$@"
